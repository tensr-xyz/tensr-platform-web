# Auth — required (app shows a configuration error if missing)
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN=

# API — required in production (defaults to http://127.0.0.1:8000 when unset)
# Local full stack: run tensr-api on :8000 and set:
#   NEXT_PUBLIC_TENSR_API_URL=http://127.0.0.1:8000
# Remote Lambda stacks (browser uses /api/tensr/* proxy):
#   NEXT_PUBLIC_TENSR_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com
NEXT_PUBLIC_TENSR_API_URL=
# Aliases also supported: NEXT_PUBLIC_API_URL, NEXT_PUBLIC_API_BASE_URL
# Deprecated (ignored if TENSR/API vars set): NEXT_PUBLIC_FARGATE_API_URL

# Billing — required for subscription and billing UI
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Realtime / collaboration WebSocket base (e.g. ws://127.0.0.1:8000/ws or wss://…execute-api…/prod)
# When set in prod, enables live presence/cell sync via RealtimeStack.
NEXT_PUBLIC_WEBSOCKET_URL=
# Set to "false" to force-disable live WebSocket collaboration (REST sessions still work).
NEXT_PUBLIC_REALTIME_COLLABORATION=

# PostHog analytics — required for product analytics and session replay
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional
NEXT_PUBLIC_DISABLE_USAGE_TRACKING=

# E2E only — never set in production (allows Playwright to bypass auth middleware locally)
E2E_AUTH_BYPASS=

# Backend only (set on tensr-api, not this app)
# OPENAI_API_KEY — required for AI assistant features on tensr-api
